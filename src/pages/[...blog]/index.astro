---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';

import merge from 'lodash.merge';
import type { ImageMetadata } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import SinglePost from '~/components/blog/SinglePost.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';

import JsonLd from '~/components/common/JsonLd.astro';
import { getCanonical, getPermalink } from '~/utils/permalinks';
import { getStaticPathsBlogPost, blogPostRobots } from '~/utils/blog';
import { findImage } from '~/utils/images';
import type { MetaData } from '~/types';
import RelatedPosts from '~/components/blog/RelatedPosts.astro';
import RelatedRail from '~/components/data/RelatedRail.astro';
import { debates } from '~/data/debates';
import { categories as policyCategories } from '~/data/policies';
import { levers } from '~/data/levers';
import { timelineEvents } from '~/data/timeline';
import { allPeople } from '~/data/people';
import type { RelatedBundle } from '~/utils/graph';

export const prerender = true;

export const getStaticPaths = (async () => {
  return await getStaticPathsBlogPost();
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { post } = Astro.props as Props;

const url = getCanonical(getPermalink(post.permalink, 'post'));
const image = (await findImage(post.image)) as ImageMetadata | string | undefined;

const metadata = merge(
  {
    title: post.title,
    description: post.excerpt,
    robots: {
      index: blogPostRobots?.index,
      follow: blogPostRobots?.follow,
    },
    openGraph: {
      type: 'article',
      ...(image
        ? { images: [{ url: image, width: (image as ImageMetadata)?.width, height: (image as ImageMetadata)?.height }] }
        : {}),
    },
  },
  { ...(post?.metadata ? { ...post.metadata, canonical: post.metadata?.canonical || url } : {}) }
) as MetaData;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.excerpt || '',
  datePublished: post.publishDate ? new Date(post.publishDate).toISOString() : undefined,
  ...(post.updateDate ? { dateModified: new Date(post.updateDate).toISOString() } : {}),
  author: { '@type': 'Organization', name: 'SG AI 观察' },
  publisher: {
    '@type': 'Organization',
    name: 'SG AI 观察',
    logo: { '@type': 'ImageObject', url: 'https://sgai.md/favicon.svg' },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': String(url) },
  inLanguage: 'zh-CN',
};

const breadcrumbs = [{ label: '深度分析', href: getPermalink('/blog') }, { label: post.title }];

// Build a RelatedBundle from frontmatter cross-refs. Each list is filtered
// against actual data so a typo in frontmatter degrades silently rather
// than emitting a broken link. verify-graph.ts catches these in CI.
const allPolicyRecords = policyCategories.flatMap((c) => c.policies);
const relatedBundle: RelatedBundle = {
  people: (post.relatedPersonIds || [])
    .map((id) => allPeople.find((p) => p.id === id))
    .filter(Boolean) as RelatedBundle['people'],
  policies: (post.relatedPolicyIds || [])
    .map((id) => allPolicyRecords.find((p) => p.id === id))
    .filter(Boolean) as RelatedBundle['policies'],
  debates: (post.relatedDebateIds || [])
    .map((id) => debates.find((d) => d.id === id))
    .filter(Boolean) as RelatedBundle['debates'],
  levers: (post.relatedLeverNumbers || [])
    .map((n) => levers.find((lv) => lv.number === n))
    .filter(Boolean) as RelatedBundle['levers'],
  timeline: (post.relatedTimelineYears || []).flatMap((y) => timelineEvents.filter((e) => e.year === y)),
  postSlugs: [],
};
---

<Layout metadata={metadata} breadcrumbs={breadcrumbs}>
  <JsonLd schema={articleSchema} />
  <SinglePost post={{ ...post, image: image }} url={url}>
    {post.Content ? <post.Content /> : <Fragment set:html={post.content || ''} />}
  </SinglePost>
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <RelatedRail bundle={relatedBundle} variant="full" />
  </div>
  <ToBlogLink />
  <RelatedPosts post={post} />
</Layout>
