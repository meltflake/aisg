---
// TODO(Task 11): rewrite as 6-dimension dashboard
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import { dataDate } from '~/data/tracker';

const lang = 'en' as const;
---

<Layout
  metadata={{
    title: 'Key Metrics',
    description:
      'Singapore AI key metrics tracker — investment, talent counts, compute infrastructure and other indicators of strategy execution.',
  }}
  breadcrumbs={[{ label: 'Key Metrics' }]}
  lang={lang}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-5xl">
    <Headline title="📊 Execution Tracker" subtitle="Dashboard rebuild in progress — coming soon." />
    <p class="text-sm text-muted">Data as of {dataDate}</p>
  </section>
</Layout>
